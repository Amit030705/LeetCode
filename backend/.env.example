PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
DB_CONNECT_STRING=
JWT_KEY=
REDIS_PASS=
GEMINI_KEY=
JUDGE0_KEY=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
